{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "lib": ["ES2020"],
    "outDir": "./dist",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "declaration": true,
    "paths": {
      "@tradeflow/shared": ["../../packages/shared/index.ts"]
    }
  },
  "include": ["src/**/*.ts", "../../packages/shared/**/*.ts"],
  "exclude": ["node_modules", "dist"]
}
